.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  height: 128rpx;
  padding: 10rpx 22rpx 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: rgba(255, 255, 255, 0.98);
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  color: #9a9aa1;
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 18rpx;
  background: #f5f5f6;
  color: #86868f;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.tab-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
}

.tab-item.active {
  color: #111111;
  font-weight: 800;
}

.tab-item.active .tab-mark {
  background: #111111;
  color: #ffffff;
}

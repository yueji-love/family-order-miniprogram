.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  height: 132rpx;
  padding: 12rpx 20rpx 28rpx;
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -16rpx 42rpx rgba(17, 17, 17, 0.08);
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border-radius: 28rpx;
  color: #8e8e93;
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 14rpx;
  background: transparent;
  font-size: 25rpx;
  font-weight: 700;
}

.tab-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1;
}

.tab-item.active {
  background: #fff1ee;
  color: #ff4f3f;
  font-weight: 700;
}

.tab-item.active .tab-mark {
  background: #ff4f3f;
  color: #fff;
}

.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  height: 128rpx;
  padding: 10rpx 22rpx 24rpx;
  border-top: 1rpx solid rgba(255, 159, 73, 0.14);
  background: rgba(255, 255, 255, 0.98);
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  color: #a89c8c;
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 18rpx;
  background: #fff4e6;
  color: #c99157;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.tab-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
}

.tab-item.active {
  color: #d2742f;
  font-weight: 900;
}

.tab-item.active .tab-mark {
  background: #ff8a3d;
  color: #ffffff;
}

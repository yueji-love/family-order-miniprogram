.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  height: 128rpx;
  padding: 10rpx 22rpx 24rpx;
  border-top: 1rpx solid rgba(122, 143, 22, 0.1);
  background: rgba(255, 255, 255, 0.98);
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  color: #a1a694;
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 18rpx;
  background: #f4f7df;
  color: #9aa16d;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.tab-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
}

.tab-item.active {
  color: #6f8312;
  font-weight: 900;
}

.tab-item.active .tab-mark {
  background: #7a8f16;
  color: #ffffff;
}

<view class="tab-shell">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-mark">{{item.mark}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>

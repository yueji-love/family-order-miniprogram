<view class="purchase-page">
  <view class="page-title">采购单</view>
  <view class="page-desc">谁买到哪一项就勾哪一项，后续会记录勾选人和时间。</view>

  <view class="group-card" wx:for="{{groups}}" wx:key="name">
    <view class="group-title">{{item.name}}</view>
    <view class="purchase-row" wx:for="{{item.items}}" wx:for-item="purchase" wx:key="name">
      <checkbox checked="{{purchase.checked}}" />
      <view class="purchase-info">
        <view class="purchase-name">{{purchase.name}} {{purchase.amount}}{{purchase.unit}}</view>
        <view class="purchase-meta" wx:if="{{purchase.checkedByName}}">{{purchase.checkedByName}} 已买</view>
      </view>
    </view>
  </view>
</view>

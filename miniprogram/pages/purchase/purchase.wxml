<view class="page">
  <view class="title">采购单</view>
  <view class="subtitle">成员买到哪项就勾哪项，系统会记录谁买的和时间。</view>

  <view class="section panel" wx:for="{{groups}}" wx:key="name">
    <view class="group-title">{{item.name}}</view>
    <view class="purchase-row" wx:for="{{item.items}}" wx:for-item="purchase" wx:key="name">
      <checkbox checked="{{purchase.checked}}" />
      <view class="purchase-info">
        <view>{{purchase.name}} {{purchase.amount}}{{purchase.unit}}</view>
        <view class="muted" wx:if="{{purchase.checkedByName}}">{{purchase.checkedByName}} 已买</view>
      </view>
    </view>
  </view>
</view>

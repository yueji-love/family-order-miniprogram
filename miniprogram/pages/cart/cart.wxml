<view class="page">
  <view class="cart-hero">
    <view class="eyebrow">提交前确认</view>
    <view class="title">购物车</view>
    <view class="subtitle">系统会根据当前时间，先帮你选好日期和餐次。</view>
  </view>

  <view class="section form-panel">
    <view class="row">
      <view>
        <view class="label">用餐日期</view>
        <view class="value">{{mealDate}}</view>
      </view>
    </view>
    <view class="row">
      <view>
        <view class="label">餐次</view>
        <view class="value">{{mealTypeName}}</view>
      </view>
      <view class="pill">自动推荐</view>
    </view>
    <view class="row">
      <view>
        <view class="label">就餐人数</view>
        <view class="value">{{servings}} 人</view>
      </view>
      <view class="stepper">
        <button bindtap="minusServing">-</button>
        <text>{{servings}}</text>
        <button bindtap="addServing">+</button>
      </view>
    </view>
  </view>

  <view class="submit-area">
    <button class="button" bindtap="submitCart">提交到共享餐单</button>
  </view>
</view>

<view class="page">
  <view class="title">购物车</view>
  <view class="subtitle">系统会根据当前时间，先帮你选好日期和餐次。</view>

  <view class="section panel">
    <view class="row">
      <text>用餐日期</text>
      <text>{{mealDate}}</text>
    </view>
    <view class="row">
      <text>餐次</text>
      <text>{{mealTypeName}}</text>
    </view>
    <view class="row">
      <text>就餐人数</text>
      <view class="stepper">
        <button bindtap="minusServing">-</button>
        <text>{{servings}}</text>
        <button bindtap="addServing">+</button>
      </view>
    </view>
  </view>

  <view class="section">
    <button class="button" bindtap="submitCart">提交到共享餐单</button>
  </view>
</view>

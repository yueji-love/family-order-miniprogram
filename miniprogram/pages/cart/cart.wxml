<view class="cart-page">
  <view class="cart-hero">
    <view class="hero-kicker">提交前确认</view>
    <view class="hero-title">购物车</view>
    <view class="hero-desc">系统会根据当前时间，先帮你选好用餐日期和餐次。</view>
  </view>

  <view class="form-panel">
    <view class="row">
      <view>
        <view class="label">用餐日期</view>
        <view class="value">{{mealDate}}</view>
      </view>
    </view>
    <view class="row">
      <view>
        <view class="label">餐次</view>
        <view class="value">{{mealTypeName}}</view>
      </view>
      <view class="pill">自动推荐</view>
    </view>
    <view class="row">
      <view>
        <view class="label">就餐人数</view>
        <view class="value">{{servings}} 人</view>
      </view>
      <view class="stepper">
        <button bindtap="minusServing">-</button>
        <text>{{servings}}</text>
        <button bindtap="addServing">+</button>
      </view>
    </view>
  </view>

  <view class="submit-area">
    <button class="submit-button" bindtap="submitCart">提交到共享餐单</button>
  </view>
</view>

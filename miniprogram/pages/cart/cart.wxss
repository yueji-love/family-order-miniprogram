.cart-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 170rpx;
  background: #fffdf6;
}

button::after {
  border: 0;
}

.cart-hero {
  box-sizing: border-box;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffb84d 0%, #ff8a3d 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255, 138, 61, 0.2);
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 46rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.5;
}

.form-panel {
  margin-top: 24rpx;
  padding: 8rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(189, 119, 54, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 118rpx;
  border-top: 1rpx solid #f2eadf;
}

.row:first-child {
  border-top: 0;
}

.label {
  color: #8f7d69;
  font-size: 24rpx;
  font-weight: 800;
}

.value {
  margin-top: 8rpx;
  color: #2b2218;
  font-size: 32rpx;
  font-weight: 900;
}

.edit-pill {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff2d5;
  color: #d2742f;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.meal-section {
  padding: 26rpx 0;
  border-top: 1rpx solid #f2eadf;
}

.meal-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.meal-option {
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff4e6;
  color: #8f7d69;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 60rpx;
}

.meal-option.active {
  background: #ff8a3d;
  color: #ffffff;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #2b2218;
  font-size: 30rpx;
  font-weight: 900;
}

.stepper button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  background: #fff2d5;
  color: #d2742f;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.submit-area {
  position: fixed;
  right: 28rpx;
  bottom: 42rpx;
  left: 28rpx;
}

.submit-button {
  height: 94rpx;
  border-radius: 26rpx;
  background: #ff8a3d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 94rpx;
  box-shadow: 0 14rpx 28rpx rgba(255, 138, 61, 0.22);
}

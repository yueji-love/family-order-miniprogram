.manage-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 80rpx;
  background: #f8f8fa;
}

.manage-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
}

.manage-kicker {
  color: #8173b4;
  font-size: 24rpx;
  font-weight: 900;
}

.manage-title {
  margin-top: 10rpx;
  color: #111111;
  font-size: 44rpx;
  font-weight: 900;
}

.manage-desc {
  margin-top: 12rpx;
  color: #7b7b84;
  font-size: 25rpx;
  line-height: 1.45;
}

.add-button {
  flex-shrink: 0;
  width: 150rpx;
  height: 66rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.category-row {
  margin: 26rpx -28rpx 10rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  margin-right: 16rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4d4d55;
  font-size: 25rpx;
  font-weight: 800;
}

.dish-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 112rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.dish-info {
  min-width: 0;
}

.dish-name {
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.dish-meta {
  margin-top: 10rpx;
  color: #8b8b94;
  font-size: 24rpx;
}

.status {
  flex-shrink: 0;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef8f1;
  color: #2d8b4e;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.status.paused {
  background: #fff2ef;
  color: #ff5a45;
}

.menu-page {
  position: relative;
  display: flex;
  min-height: 100vh;
  padding-top: 172rpx;
  padding-bottom: 220rpx;
  background: #f6f7f1;
}

.menu-header {
  position: fixed;
  z-index: 3;
  top: 0;
  right: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-sizing: border-box;
  height: 172rpx;
  padding: 34rpx 28rpx 24rpx;
  background: #f6f7f1;
}

.menu-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.menu-count {
  min-width: 82rpx;
  height: 50rpx;
  border-radius: 999rpx;
  background: #26352f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 50rpx;
  text-align: center;
}

.sidebar {
  width: 176rpx;
  background: #edf2e8;
}

.category {
  margin: 10rpx 12rpx;
  padding: 22rpx 14rpx;
  border-radius: 8rpx;
  color: #687067;
  font-size: 28rpx;
}

.category.active {
  background: #fffefa;
  color: #246b5a;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(63, 78, 68, 0.08);
}

.dish-list {
  flex: 1;
  height: calc(100vh - 304rpx);
  padding: 24rpx;
  box-sizing: border-box;
}

.dish {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(39, 68, 59, 0.08);
  border-radius: 8rpx;
  background: #fffefa;
  box-shadow: 0 12rpx 32rpx rgba(63, 78, 68, 0.07);
}

.dish-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 8rpx;
  background: #e4f0e7;
  color: #246b5a;
  font-size: 44rpx;
  font-weight: 700;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 700;
}

.dish-tag,
.dish-status {
  margin-top: 8rpx;
  color: #687067;
  font-size: 24rpx;
}

.dish-status.disabled {
  color: #a65f42;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 50%;
  background: #246b5a;
  color: #fff;
  line-height: 64rpx;
  box-shadow: 0 10rpx 22rpx rgba(36, 107, 90, 0.2);
}

.cart-bar {
  position: fixed;
  right: 24rpx;
  bottom: 128rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 8rpx;
  background: #26352f;
  color: #fff;
  font-size: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(38, 53, 47, 0.24);
}

.cart-title {
  font-size: 28rpx;
  font-weight: 700;
}

.cart-sub {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
}

.cart-total {
  color: #f0b84d;
  font-size: 28rpx;
  font-weight: 700;
}

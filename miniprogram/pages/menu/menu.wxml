<view class="manage-page">
  <view class="manage-header">
    <view>
      <view class="manage-kicker">主理人</view>
      <view class="manage-title">菜单管理</view>
      <view class="manage-desc">菜品图片、食材用量和上架状态只在这里维护。</view>
    </view>
    <button class="add-button" bindtap="addRecipe">添加菜谱</button>
  </view>

  <scroll-view class="category-row" scroll-x>
    <view class="category-chip" wx:for="{{categories}}" wx:key="*this">{{item}}</view>
  </scroll-view>

  <view class="dish-card" wx:for="{{dishes}}" wx:key="id" bindtap="editDish">
    <view class="dish-info">
      <view class="dish-name">{{item.name}}</view>
      <view class="dish-meta">{{item.category}} · 总点餐 {{item.sales}}</view>
    </view>
    <view class="status {{item.status === '暂不可做' ? 'paused' : ''}}">{{item.status}}</view>
  </view>
</view>

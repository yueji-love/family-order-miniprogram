<view class="profile-page">
  <view class="profile-card">
    <view class="profile-kicker">{{familyName}}</view>
    <view class="profile-title">我的</view>
    <view class="profile-role">当前身份：{{roleName}}</view>
  </view>

  <view class="id-grid">
    <view class="id-card" data-value="{{familyId}}" bindtap="copyId">
      <view class="id-label">家庭 ID</view>
      <view class="id-value">{{familyId}}</view>
    </view>
    <view class="id-card" data-value="{{roleId}}" bindtap="copyId">
      <view class="id-label">主理人 ID</view>
      <view class="id-value">{{roleId}}</view>
    </view>
    <view class="id-card" data-value="{{memberId}}" bindtap="copyId">
      <view class="id-label">我的成员 ID</view>
      <view class="id-value">{{memberId}}</view>
    </view>
  </view>

  <view class="section-title">主理人管理</view>
  <view class="manager-list">
    <view
      wx:for="{{managerActions}}"
      wx:key="title"
      class="manager-card"
      data-index="{{index}}"
      bindtap="goAction"
    >
      <view>
        <view class="manager-title">{{item.title}}</view>
        <view class="manager-desc">{{item.desc}}</view>
      </view>
      <view class="manager-arrow">›</view>
    </view>
  </view>

  <view class="section-title">权限说明</view>
  <view class="tips-card">
    <view class="tip" wx:for="{{memberTips}}" wx:key="*this">{{item}}</view>
  </view>
</view>

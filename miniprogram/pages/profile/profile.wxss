.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 170rpx;
  background: #fffdf6;
}

.profile-card {
  box-sizing: border-box;
  min-height: 210rpx;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffb84d 0%, #ff8a3d 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255, 138, 61, 0.2);
}

.profile-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 800;
}

.profile-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.profile-role {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 27rpx;
  font-weight: 700;
}

.id-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.id-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(189, 119, 54, 0.08);
}

.id-label {
  color: #8f7d69;
  font-size: 24rpx;
  font-weight: 800;
}

.id-value {
  color: #d2742f;
  font-size: 27rpx;
  font-weight: 900;
}

.section-title {
  margin: 34rpx 4rpx 18rpx;
  color: #2b2218;
  font-size: 30rpx;
  font-weight: 900;
}

.manager-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.manager-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 132rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(189, 119, 54, 0.08);
}

.manager-title {
  color: #2b2218;
  font-size: 30rpx;
  font-weight: 900;
}

.manager-desc {
  margin-top: 10rpx;
  color: #8f7d69;
  font-size: 24rpx;
  line-height: 1.4;
}

.manager-arrow {
  color: #ffb84d;
  font-size: 48rpx;
  font-weight: 300;
}

.tips-card {
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(189, 119, 54, 0.08);
}

.tip {
  padding: 22rpx 0;
  border-top: 1rpx solid #f2eadf;
  color: #806f5f;
  font-size: 26rpx;
  line-height: 1.5;
}

.tip:first-child {
  border-top: 0;
}

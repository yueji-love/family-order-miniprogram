.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 170rpx;
  background: #f8f8fa;
}

.profile-card {
  box-sizing: border-box;
  min-height: 220rpx;
  padding: 34rpx 32rpx;
  border-radius: 30rpx;
  background: #111111;
  color: #ffffff;
}

.profile-kicker {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.profile-role {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 27rpx;
}

.section-title {
  margin: 34rpx 4rpx 18rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.manager-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.manager-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 132rpx;
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
}

.manager-title {
  color: #171717;
  font-size: 30rpx;
  font-weight: 900;
}

.manager-desc {
  margin-top: 10rpx;
  color: #7b7b84;
  font-size: 24rpx;
  line-height: 1.4;
}

.manager-arrow {
  color: #c2c2c9;
  font-size: 48rpx;
  font-weight: 300;
}

.tips-card {
  padding: 10rpx 28rpx;
  border-radius: 26rpx;
  background: #ffffff;
}

.tip {
  padding: 22rpx 0;
  border-top: 1rpx solid #eeeeF2;
  color: #686872;
  font-size: 26rpx;
  line-height: 1.5;
}

.tip:first-child {
  border-top: 0;
}

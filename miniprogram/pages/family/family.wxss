.family-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 150rpx;
  background: #fffdf6;
}

.family-hero {
  box-sizing: border-box;
  padding: 38rpx 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffb84d 0%, #ff8a3d 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255, 138, 61, 0.2);
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.18;
}

.hero-desc {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
}

.id-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.id-card,
.family-panel {
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(189, 119, 54, 0.08);
}

.id-card {
  min-height: 112rpx;
  padding: 22rpx;
}

.id-label {
  color: #8f7d69;
  font-size: 23rpx;
  font-weight: 800;
}

.id-value {
  margin-top: 10rpx;
  color: #d2742f;
  font-size: 27rpx;
  font-weight: 900;
}

.family-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.field-label {
  margin-bottom: 18rpx;
  color: #2b2218;
  font-size: 30rpx;
  font-weight: 900;
}

input {
  box-sizing: border-box;
  width: 100%;
  height: 90rpx;
  padding: 0 22rpx;
  border: 2rpx solid #f2dfc3;
  border-radius: 20rpx;
  background: #ffffff;
  color: #2b2218;
  font-size: 28rpx;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 92rpx;
  margin-top: 26rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
}

.primary-button {
  background: #ff8a3d;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 138, 61, 0.22);
}

.secondary-button {
  border: 2rpx solid #ffd59c;
  background: #ffffff;
  color: #d2742f;
}

.member-id {
  margin-top: 24rpx;
  color: #8f7d69;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

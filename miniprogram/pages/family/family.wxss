.family-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 150rpx;
  background: #f8f8fa;
}

.family-hero {
  box-sizing: border-box;
  padding: 38rpx 34rpx;
  border-radius: 30rpx;
  background: #111111;
  color: #ffffff;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.18;
}

.hero-desc {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  line-height: 1.55;
}

.family-panel {
  box-sizing: border-box;
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
}

.field-label {
  margin-bottom: 18rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

input {
  box-sizing: border-box;
  width: 100%;
  height: 90rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e8e8ee;
  border-radius: 18rpx;
  background: #ffffff;
  color: #111111;
  font-size: 28rpx;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 92rpx;
  margin-top: 26rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
}

.primary-button {
  background: #111111;
  color: #ffffff;
}

.secondary-button {
  border: 2rpx solid #dedee5;
  background: #ffffff;
  color: #111111;
}

<view class="order-page">
  <view wx:if="{{!hasFamily}}" class="family-setup">
    <view class="setup-title">先有一个家，再开始点菜</view>
    <view class="setup-desc">主理人创建家庭并邀请成员；成员加入后，首页会直接显示这一顿可点的菜单。</view>
    <view class="setup-actions">
      <button class="setup-primary" bindtap="goFamily">创建或加入家庭</button>
      <button class="setup-secondary" bindtap="goFamily">输入邀请码</button>
    </view>
  </view>

  <view wx:else class="order-shell">
    <view class="topbar">
      <view class="tabs">
        <view class="tab active">点单</view>
        <view class="tab muted" bindtap="goProfile">管理</view>
      </view>
      <button wx:if="{{role === '主理人'}}" class="add-recipe" bindtap="goMenuManage">添加菜谱</button>
      <view class="search-box">
        <text class="search-icon">⌕</text>
        <input
          value="{{searchKeyword}}"
          placeholder="搜索"
          confirm-type="search"
          bindinput="onSearchInput"
        />
      </view>
    </view>

    <view class="meal-strip">
      <view>
        <view class="family-name">{{familyName}}</view>
        <view class="meal-name">{{defaultMeal.mealDate}} {{defaultMeal.mealTypeName}}</view>
      </view>
      <view class="role-pill">{{role}}</view>
    </view>

    <view class="content">
      <scroll-view class="category-list" scroll-y>
        <view
          wx:for="{{categories}}"
          wx:key="*this"
          class="category-item {{currentCategory === item ? 'active' : ''}}"
          data-name="{{item}}"
          bindtap="selectCategory"
        >{{item}}</view>
      </scroll-view>

      <scroll-view class="dish-list" scroll-y>
        <view class="category-title">{{currentCategory}}({{visibleDishes.length}})</view>
        <view class="dish-row" wx:for="{{visibleDishes}}" wx:key="id">
          <view class="dish-thumb" style="background: {{item.color}};">
            <text>{{item.thumb}}</text>
          </view>
          <view class="dish-main">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-sales">月销 {{item.sales}}</view>
            <view wx:if="{{item.selected > 0}}" class="dish-selected">已点 {{item.selected}} 份</view>
          </view>
          <button class="plus-btn" data-id="{{item.id}}" bindtap="addDish">+</button>
        </view>
        <view wx:if="{{visibleDishes.length === 0}}" class="empty-dish">没有找到这道菜</view>
      </scroll-view>
    </view>

    <view class="floating-cart">
      <view class="cart-icon">车</view>
      <button class="random-btn" bindtap="randomDish">随机选菜</button>
      <button class="invite-btn" bindtap="goFamily">邀请下单</button>
      <button class="submit-btn {{cartCount === 0 ? 'disabled' : ''}}" bindtap="goCart">{{submitText}}</button>
    </view>
  </view>
</view>

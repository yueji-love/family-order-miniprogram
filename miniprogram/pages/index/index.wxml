<view class="page">
  <view class="home-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="home-tab {{currentTab === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchHomeTab"
    >{{item}}</view>
  </view>

  <view class="roulette-hero">
    <view class="hero-top">
      <view>
        <view class="hero-kicker">今天吃什么</view>
        <view class="hero-title">{{defaultMeal.mealTypeName}} 转一下</view>
      </view>
      <view class="hero-date">{{defaultMeal.mealDate}}</view>
    </view>

    <view class="wheel-wrap">
      <view class="pointer"></view>
      <view class="wheel">
        <view
          wx:for="{{wheelItems}}"
          wx:key="name"
          class="wheel-label"
          style="transform: rotate({{item.rotate}}deg) translateY(-198rpx);"
        >
          <text style="transform: rotate(-{{item.rotate}}deg);">{{item.name}}</text>
        </view>
        <view class="wheel-center">
          <view class="center-dot"></view>
        </view>
      </view>
    </view>

    <button class="spin-button" bindtap="goMenu">开始点菜</button>
  </view>

  <view class="chip-panel">
    <view class="chip" wx:for="{{chips}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="status-strip">
    <view class="status-title" wx:if="{{loading}}">正在连接微信云开发...</view>
    <view class="status-title" wx:elif="{{user}}">已识别当前微信用户</view>
    <view class="status-title" wx:else>还没有完成登录验证</view>
    <view class="status-desc">可以继续创建家庭，或先看看点菜页。</view>
  </view>

  <view class="quick-actions">
    <view class="quick-action primary" bindtap="goFamily">
      <view class="quick-title">创建或加入家庭</view>
      <view class="quick-desc">主理人建家，成员用邀请码加入</view>
    </view>
    <view class="quick-action" bindtap="goMenu">
      <view class="quick-title">看看点菜页</view>
      <view class="quick-desc">先体验共享点菜流程</view>
    </view>
  </view>
</view>

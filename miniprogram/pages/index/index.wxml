<view class="order-page">
  <view wx:if="{{!hasFamily}}" class="family-setup">
    <view class="setup-title">先有一个家，再开始点菜</view>
    <view class="setup-desc">主理人创建家庭并邀请成员；成员加入后，首页会直接显示可点的菜单。</view>
    <view class="setup-actions">
      <button class="setup-primary" bindtap="goFamily">创建或加入家庭</button>
      <button class="setup-secondary" bindtap="goFamily">输入邀请码</button>
    </view>
  </view>

  <view wx:else class="order-shell">
    <view class="topbar">
      <view class="nav-row">
        <view class="tabs">
          <view class="tab active">点单</view>
          <view class="tab muted" bindtap="goMenuManage">管理</view>
        </view>
        <view class="search-circle" bindtap="openSearch">
          <view class="search-icon"></view>
        </view>
      </view>
      <view class="action-row">
        <button wx:if="{{role === '主理人'}}" class="add-recipe" bindtap="goMenuManage">添加菜谱</button>
        <view class="search-box">
          <view class="search-icon small"></view>
        <input
          value="{{searchKeyword}}"
          placeholder="搜索"
          confirm-type="search"
          bindinput="onSearchInput"
        />
        <text wx:if="{{searchKeyword}}" class="clear-search" bindtap="clearSearch">×</text>
        </view>
      </view>
    </view>

    <view class="content">
      <scroll-view class="category-list" scroll-y>
        <view
          wx:for="{{categories}}"
          wx:key="*this"
          class="category-item {{!isSearching && currentCategory === item ? 'active' : ''}}"
          data-name="{{item}}"
          bindtap="selectCategory"
        >{{item}}</view>
      </scroll-view>

      <scroll-view class="dish-list" scroll-y>
        <view class="category-title">{{listTitle}}</view>
        <view class="dish-row" wx:for="{{visibleDishes}}" wx:key="id">
          <view class="dish-thumb" style="background: {{item.color}};">
            <text>{{item.thumb}}</text>
          </view>
          <view class="dish-main">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-sales">月销 {{item.sales}}</view>
            <view wx:if="{{item.selected > 0}}" class="dish-selected">已点 {{item.selected}} 份</view>
          </view>
          <button class="plus-btn" data-id="{{item.id}}" bindtap="addDish">+</button>
        </view>
        <view wx:if="{{visibleDishes.length === 0}}" class="empty-dish">没有找到这道菜</view>
      </scroll-view>
    </view>

    <view class="settle-bar">
      <view class="cart-icon" bindtap="openCartDrawer">
        <image class="cart-image" src="/assets/icons/cart.png" mode="aspectFit" />
        <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
      </view>
      <button class="random-btn" bindtap="randomDish">随机选菜</button>
      <view class="cart-summary" bindtap="openCartDrawer">
        <view class="summary-main">已选 {{cartCount}} 道</view>
        <view class="summary-sub">点购物车查看</view>
      </view>
      <button class="order-btn {{cartCount === 0 ? 'disabled' : ''}}" bindtap="goCart">下单</button>
    </view>

    <view wx:if="{{cartDrawerVisible}}" class="drawer-mask" bindtap="closeCartDrawer"></view>
    <view class="cart-drawer {{cartDrawerVisible ? 'open' : ''}}">
      <view class="drawer-handle"></view>
      <view class="drawer-head">
        <view>
          <view class="drawer-title">购物车</view>
          <view class="drawer-subtitle">{{cartCount}} 道已选菜</view>
        </view>
        <view class="drawer-close" bindtap="closeCartDrawer">×</view>
      </view>

      <view wx:if="{{cartItems.length === 0}}" class="drawer-empty">还没点菜，先加一道喜欢的。</view>
      <view wx:else class="drawer-list">
        <view class="drawer-row" wx:for="{{cartItems}}" wx:key="id">
          <view class="drawer-dish">
            <view class="drawer-name">{{item.name}}</view>
            <view class="drawer-meta">{{item.category}}</view>
          </view>
          <view class="drawer-stepper">
            <button data-id="{{item.id}}" bindtap="reduceDish">-</button>
            <text>{{item.selected}}</text>
            <button data-id="{{item.id}}" bindtap="addDish">+</button>
          </view>
        </view>
      </view>

      <button class="confirm-cart {{cartCount === 0 ? 'disabled' : ''}}" bindtap="goCart">去确认下单</button>
    </view>
  </view>
</view>

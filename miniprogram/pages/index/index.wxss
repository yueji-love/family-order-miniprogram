.order-page {
  min-height: 100vh;
  background: #fffdf6;
}

.family-setup {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 180rpx 48rpx;
  background: linear-gradient(180deg, #fff4ce 0%, #fffdf6 42%);
}

.setup-title {
  color: #2b2218;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.18;
}

.setup-desc {
  margin-top: 22rpx;
  color: #7b6f63;
  font-size: 28rpx;
  line-height: 1.7;
}

.setup-actions {
  margin-top: 56rpx;
}

.setup-primary,
.setup-secondary {
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 96rpx;
}

.setup-primary {
  background: #ff8a3d;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 138, 61, 0.24);
}

.setup-secondary {
  margin-top: 22rpx;
  border: 2rpx solid #ffd59c;
  background: #ffffff;
  color: #d66a21;
}

.order-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 250rpx;
  background: #fffdf6;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
  height: 116rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid #f1e8d7;
  background: rgba(255, 253, 246, 0.98);
}

.tabs {
  display: flex;
  align-items: center;
  gap: 24rpx;
  height: 72rpx;
}

.tab {
  position: relative;
  color: #2d261f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.tab.active::after {
  position: absolute;
  bottom: 2rpx;
  left: 4rpx;
  width: 48rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #ff8a3d;
  content: "";
}

.tab.muted {
  color: #9a928a;
  font-weight: 700;
}

.add-recipe {
  width: 142rpx;
  height: 64rpx;
  padding: 0;
  border: 2rpx solid #f5bd73;
  border-radius: 18rpx;
  background: #ffffff;
  color: #c96720;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff4e6;
}

.search-icon {
  margin-right: 8rpx;
  color: #d2742f;
  font-size: 22rpx;
  font-weight: 900;
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #2d261f;
  font-size: 25rpx;
}

.clear-search {
  width: 34rpx;
  color: #b7a58f;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.meal-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 112rpx;
  padding: 16rpx 24rpx 16rpx 28rpx;
  background: #ffffff;
}

.family-name {
  color: #8f7d69;
  font-size: 24rpx;
  font-weight: 800;
}

.meal-name {
  margin-top: 6rpx;
  color: #2d261f;
  font-size: 33rpx;
  font-weight: 900;
}

.id-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.role-pill,
.id-pill {
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.role-pill {
  background: #eaffef;
  color: #25a45a;
}

.id-pill {
  background: #fff2d5;
  color: #d2742f;
}

.content {
  display: flex;
  height: calc(100vh - 228rpx);
  min-height: 720rpx;
  border-top: 1rpx solid #f2eadf;
}

.category-list {
  width: 178rpx;
  height: 100%;
  background: #fff7ea;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 106rpx;
  padding: 10rpx 14rpx;
  color: #806f5f;
  font-size: 27rpx;
  line-height: 1.25;
  text-align: center;
}

.category-item.active {
  background: #ffffff;
  color: #2b2218;
  font-size: 29rpx;
  font-weight: 900;
}

.category-item.active::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: #ff8a3d;
  content: "";
}

.dish-list {
  flex: 1;
  height: 100%;
  box-sizing: border-box;
  padding: 22rpx 22rpx 210rpx;
  background: #ffffff;
}

.category-title {
  margin-bottom: 20rpx;
  color: #2b2218;
  font-size: 32rpx;
  font-weight: 900;
}

.dish-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 154rpx;
  margin-bottom: 22rpx;
}

.dish-thumb {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  overflow: hidden;
  border-radius: 18rpx;
  box-shadow: inset 0 -18rpx 34rpx rgba(120, 80, 20, 0.12);
}

.dish-thumb::after {
  position: absolute;
  right: 13rpx;
  bottom: 12rpx;
  width: 38rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.5);
  content: "";
}

.dish-thumb text {
  z-index: 1;
  color: rgba(255, 255, 255, 0.96);
  font-size: 42rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.14);
}

.dish-main {
  flex: 1;
  min-width: 0;
  padding: 0 60rpx 0 22rpx;
}

.dish-name {
  color: #2b2218;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.28;
}

.dish-sales {
  margin-top: 16rpx;
  color: #a89c8c;
  font-size: 26rpx;
}

.dish-selected {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  margin-top: 10rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a2f;
  font-size: 21rpx;
  font-weight: 900;
}

.plus-btn {
  position: absolute;
  right: 4rpx;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-top: -24rpx;
  padding: 0;
  border-radius: 50%;
  background: #ff8a3d;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 44rpx;
  box-shadow: 0 8rpx 18rpx rgba(255, 138, 61, 0.24);
}

.empty-dish {
  margin-top: 90rpx;
  color: #a89c8c;
  font-size: 28rpx;
  text-align: center;
}

.floating-cart {
  position: fixed;
  right: 18rpx;
  bottom: 132rpx;
  left: 18rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 108rpx;
  box-sizing: border-box;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 159, 73, 0.18);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 10rpx 34rpx rgba(189, 119, 54, 0.14);
}

.cart-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  background: #fff2d5;
  color: #d2742f;
  font-size: 28rpx;
  font-weight: 900;
}

.cart-preview {
  flex: 1;
  min-width: 0;
}

.cart-title {
  color: #2b2218;
  font-size: 24rpx;
  font-weight: 900;
}

.cart-dishes {
  overflow: hidden;
  margin-top: 5rpx;
  color: #8f7d69;
  font-size: 22rpx;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.random-btn,
.submit-btn {
  flex-shrink: 0;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.random-btn {
  border: 2rpx solid #ffd59c;
  background: #ffffff;
  color: #d2742f;
}

.submit-btn {
  min-width: 104rpx;
  background: #ff8a3d;
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(255, 138, 61, 0.2);
}

.submit-btn.disabled {
  background: #f1ede8;
  color: #c8bfb4;
  box-shadow: none;
}

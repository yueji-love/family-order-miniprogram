.home-tabs {
  display: flex;
  align-items: center;
  height: 78rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #f0f0f2;
}

.home-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 18rpx;
  color: #222;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 62rpx;
  text-align: center;
}

.home-tab.active {
  background: #fff;
  color: #ff4f3f;
  box-shadow: 0 8rpx 20rpx rgba(17, 17, 17, 0.08);
}

.roulette-hero {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 34rpx 24rpx 42rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ff5545 0%, #ff4738 100%);
  color: #fff;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 6rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.hero-date {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 700;
}

.wheel-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  margin-top: 34rpx;
  padding-top: 24rpx;
}

.pointer {
  position: absolute;
  top: 22rpx;
  left: 50%;
  z-index: 4;
  width: 0;
  height: 0;
  margin-left: -22rpx;
  border-right: 22rpx solid transparent;
  border-left: 22rpx solid transparent;
  border-bottom: 74rpx solid #ffefea;
}

.wheel {
  position: relative;
  width: 540rpx;
  height: 540rpx;
  border: 14rpx solid #2c2c2c;
  border-radius: 50%;
  background: conic-gradient(
    #303030 0deg 45deg,
    #383838 45deg 90deg,
    #303030 90deg 135deg,
    #383838 135deg 180deg,
    #303030 180deg 225deg,
    #383838 225deg 270deg,
    #303030 270deg 315deg,
    #383838 315deg 360deg
  );
  box-shadow: 0 24rpx 36rpx rgba(28, 28, 28, 0.32);
}

.wheel-label {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 48rpx;
  margin-top: -24rpx;
  margin-left: -80rpx;
  color: #fff;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
}

.wheel-label text {
  display: block;
  width: 160rpx;
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  margin-top: -56rpx;
  margin-left: -56rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: inset 0 0 0 16rpx #f4f4f4;
}

.center-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ff4f3f;
}

.spin-button {
  width: 260rpx;
  height: 76rpx;
  margin: 28rpx auto 0;
  border-radius: 999rpx;
  background: #fff;
  color: #ff4f3f;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 76rpx;
  box-shadow: 0 14rpx 28rpx rgba(17, 17, 17, 0.16);
}

.chip-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 18rpx;
  justify-content: center;
  padding: 36rpx 12rpx 20rpx;
}

.chip {
  min-width: 176rpx;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  color: #1e1e1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
}

.chip:first-child {
  border: 2rpx solid #ff4f3f;
  background: #fff;
  color: #ff4f3f;
}

.status-strip {
  margin-top: 20rpx;
  box-sizing: border-box;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: #171717;
  color: #fff;
}

.status-title {
  font-size: 28rpx;
  font-weight: 800;
}

.status-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 24rpx;
}

.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.quick-action {
  flex: 1;
  min-height: 132rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f5f5f7;
}

.quick-action.primary {
  background: #fff1ee;
}

.quick-title {
  color: #171717;
  font-size: 27rpx;
  font-weight: 800;
}

.quick-desc {
  margin-top: 10rpx;
  color: #747474;
  font-size: 22rpx;
  line-height: 1.35;
}

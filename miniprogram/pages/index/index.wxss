.order-page {
  min-height: 100vh;
  background: #fffdf6;
}

button::after {
  border: 0;
}

.family-setup {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 180rpx 48rpx;
  background: linear-gradient(180deg, #fff4ce 0%, #fffdf6 42%);
}

.setup-title {
  color: #2b2218;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.18;
}

.setup-desc {
  margin-top: 22rpx;
  color: #7b6f63;
  font-size: 28rpx;
  line-height: 1.7;
}

.setup-actions {
  margin-top: 56rpx;
}

.setup-primary,
.setup-secondary {
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 96rpx;
}

.setup-primary {
  background: #ff8a3d;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 138, 61, 0.24);
}

.setup-secondary {
  margin-top: 22rpx;
  border: 2rpx solid #ffd59c;
  background: #ffffff;
  color: #d66a21;
}

.order-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 204rpx;
  background: #fffdf6;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  box-sizing: border-box;
  height: 152rpx;
  padding: 88rpx 190rpx 12rpx 18rpx;
  border-bottom: 1rpx solid #f1e8d7;
  background: rgba(255, 253, 246, 0.98);
}

.tabs {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 20rpx;
  height: 70rpx;
}

.tab {
  position: relative;
  color: #2d261f;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 70rpx;
}

.tab.active::after {
  position: absolute;
  bottom: 0;
  left: 4rpx;
  width: 46rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #ff8a3d;
  content: "";
}

.tab.muted {
  color: #9a928a;
  font-weight: 700;
}

.add-recipe {
  flex-shrink: 0;
  width: 168rpx;
  height: 60rpx;
  padding: 0;
  border: 2rpx solid #f5bd73;
  border-radius: 18rpx;
  background: #ffffff;
  color: #c96720;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.search-box {
  display: flex;
  flex: none;
  align-items: center;
  width: 138rpx;
  min-width: 138rpx;
  height: 60rpx;
  box-sizing: border-box;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #fff4e6;
}

.search-icon {
  position: relative;
  display: block;
  flex-shrink: 0;
  width: 22rpx;
  height: 22rpx;
  margin-right: 6rpx;
  border: 4rpx solid #d2742f;
  border-radius: 50%;
}

.search-icon::after {
  position: absolute;
  right: -9rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #d2742f;
  transform: rotate(45deg);
  content: "";
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #2d261f;
  font-size: 24rpx;
}

.clear-search {
  width: 32rpx;
  color: #b7a58f;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

.content {
  display: flex;
  height: calc(100vh - 152rpx);
  min-height: 760rpx;
}

.category-list {
  width: 178rpx;
  height: 100%;
  background: #fff7ea;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 106rpx;
  padding: 10rpx 14rpx;
  color: #806f5f;
  font-size: 27rpx;
  line-height: 1.25;
  text-align: center;
}

.category-item.active {
  background: #ffffff;
  color: #2b2218;
  font-size: 29rpx;
  font-weight: 900;
}

.category-item.active::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: #ff8a3d;
  content: "";
}

.dish-list {
  flex: 1;
  height: 100%;
  box-sizing: border-box;
  padding: 22rpx 22rpx 176rpx;
  background: #ffffff;
}

.category-title {
  margin-bottom: 20rpx;
  color: #2b2218;
  font-size: 32rpx;
  font-weight: 900;
}

.dish-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 142rpx;
  margin-bottom: 20rpx;
}

.dish-thumb {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  border-radius: 18rpx;
  box-shadow: inset 0 -18rpx 34rpx rgba(120, 80, 20, 0.12);
}

.dish-thumb::after {
  position: absolute;
  right: 12rpx;
  bottom: 11rpx;
  width: 36rpx;
  height: 15rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.5);
  content: "";
}

.dish-thumb text {
  z-index: 1;
  color: rgba(255, 255, 255, 0.96);
  font-size: 40rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.14);
}

.dish-main {
  flex: 1;
  min-width: 0;
  padding: 0 52rpx 0 22rpx;
}

.dish-name {
  color: #2b2218;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.dish-sales {
  margin-top: 14rpx;
  color: #a89c8c;
  font-size: 25rpx;
}

.dish-selected {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  margin-top: 8rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a2f;
  font-size: 20rpx;
  font-weight: 900;
}

.plus-btn {
  position: absolute;
  right: 8rpx;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 38rpx;
  min-width: 38rpx;
  max-width: 38rpx;
  height: 38rpx;
  min-height: 38rpx;
  margin: -19rpx 0 0;
  padding: 0;
  border-radius: 50%;
  background: #ff8a3d;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  box-shadow: 0 6rpx 14rpx rgba(255, 138, 61, 0.22);
}

.empty-dish {
  margin-top: 90rpx;
  color: #a89c8c;
  font-size: 28rpx;
  text-align: center;
}

.mini-cart {
  position: fixed;
  right: 24rpx;
  bottom: 136rpx;
  left: 24rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 78rpx;
  box-sizing: border-box;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(255, 159, 73, 0.18);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 8rpx 26rpx rgba(189, 119, 54, 0.14);
}

.cart-icon {
  position: relative;
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx #ffe2b8;
}

.cart-image {
  width: 42rpx;
  height: 42rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
  border: 3rpx solid #ffffff;
  border-radius: 999rpx;
  background: #ff5f3d;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 30rpx;
  text-align: center;
}

.random-btn,
.order-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.random-btn {
  width: auto;
  min-width: 170rpx;
  border: 2rpx solid #ffd59c;
  background: #ffffff;
  color: #d2742f;
}

.cart-spacer {
  flex: 1;
}

.order-btn {
  width: auto;
  min-width: 112rpx;
  background: #ff8a3d;
  color: #ffffff;
}

.order-btn.disabled {
  background: #f1ede8;
  color: #c8bfb4;
}

.drawer-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  background: rgba(43, 34, 24, 0.22);
}

.cart-drawer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 61;
  box-sizing: border-box;
  max-height: 80vh;
  padding: 14rpx 28rpx 38rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 48rpx rgba(43, 34, 24, 0.16);
  transform: translateY(110%);
  transition: transform 180ms ease;
}

.cart-drawer.open {
  transform: translateY(0);
}

.drawer-handle {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #eadfce;
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.drawer-title {
  color: #2b2218;
  font-size: 34rpx;
  font-weight: 900;
}

.drawer-subtitle {
  margin-top: 6rpx;
  color: #8f7d69;
  font-size: 24rpx;
}

.drawer-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff4e6;
  color: #d2742f;
  font-size: 40rpx;
  line-height: 52rpx;
  text-align: center;
}

.drawer-empty {
  padding: 46rpx 0;
  color: #a89c8c;
  font-size: 27rpx;
  text-align: center;
}

.drawer-list {
  max-height: 520rpx;
  overflow: hidden;
}

.drawer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 86rpx;
  border-top: 1rpx solid #f2eadf;
}

.drawer-row:first-child {
  border-top: 0;
}

.drawer-dish {
  min-width: 0;
}

.drawer-name {
  color: #2b2218;
  font-size: 28rpx;
  font-weight: 900;
}

.drawer-meta {
  margin-top: 6rpx;
  color: #a89c8c;
  font-size: 22rpx;
}

.drawer-stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #2b2218;
  font-size: 27rpx;
  font-weight: 900;
}

.drawer-stepper button {
  width: 46rpx;
  height: 46rpx;
  padding: 0;
  border-radius: 50%;
  background: #fff2d5;
  color: #d2742f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.confirm-cart {
  width: 330rpx;
  height: 88rpx;
  margin: 24rpx auto 0;
  border-radius: 24rpx;
  background: #ff8a3d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
  box-shadow: 0 12rpx 26rpx rgba(255, 138, 61, 0.22);
}

.confirm-cart.disabled {
  background: #f1ede8;
  color: #c8bfb4;
  box-shadow: none;
}

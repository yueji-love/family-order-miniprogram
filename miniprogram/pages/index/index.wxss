.order-page {
  min-height: 100vh;
  background: #f7f8f3;
  color: #2f3327;
}

button::after {
  border: 0;
}

.family-setup {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 180rpx 48rpx;
  background: linear-gradient(180deg, #edf6c7 0%, #f7f8f3 46%);
}

.setup-title {
  color: #2f3327;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.18;
}

.setup-desc {
  margin-top: 22rpx;
  color: #7a8068;
  font-size: 28rpx;
  line-height: 1.7;
}

.setup-actions {
  margin-top: 56rpx;
}

.setup-primary,
.setup-secondary {
  height: 96rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 96rpx;
}

.setup-primary {
  background: #7a8f16;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(122, 143, 22, 0.18);
}

.setup-secondary {
  margin-top: 22rpx;
  border: 2rpx solid #dce7a5;
  background: #ffffff;
  color: #6f8312;
}

.order-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  background: #f7f8f3;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  box-sizing: border-box;
  height: 210rpx;
  padding: 88rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #e8ebdf;
  background: rgba(247, 248, 243, 0.98);
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  height: 58rpx;
  padding-right: 210rpx;
}

.tabs {
  display: flex;
  align-items: center;
  gap: 22rpx;
  height: 58rpx;
}

.tab {
  position: relative;
  color: #2f3327;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.tab.active::after {
  position: absolute;
  bottom: 0;
  left: 2rpx;
  width: 44rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #7a8f16;
  content: "";
}

.tab.muted {
  color: #8e927f;
  font-weight: 800;
}

.search-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx #e6e8dc, 0 8rpx 18rpx rgba(47, 51, 39, 0.05);
}

.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 70rpx;
  margin-top: 10rpx;
  padding-right: 210rpx;
}

.add-recipe {
  flex-shrink: 0;
  width: 260rpx;
  height: 58rpx;
  padding: 0;
  border: 2rpx solid #cfdc8e;
  border-radius: 999rpx;
  background: #ffffff;
  color: #6f8312;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 54rpx;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  height: 58rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx #e8ebdf;
}

.search-icon {
  position: relative;
  display: block;
  flex-shrink: 0;
  width: 21rpx;
  height: 21rpx;
  margin-right: 10rpx;
  border: 4rpx solid #7a8f16;
  border-radius: 50%;
}

.search-icon::after {
  position: absolute;
  right: -9rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #7a8f16;
  transform: rotate(45deg);
  content: "";
}

.search-icon.small {
  width: 18rpx;
  height: 18rpx;
  border-width: 3rpx;
}

.search-icon.small::after {
  right: -8rpx;
  bottom: -6rpx;
  width: 11rpx;
  height: 3rpx;
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #2f3327;
  font-size: 24rpx;
}

.clear-search {
  width: 32rpx;
  color: #a7aa98;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

.content {
  display: flex;
  height: calc(100vh - 210rpx);
  min-height: 720rpx;
}

.category-list {
  width: 178rpx;
  height: 100%;
  background: #f0f2ea;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 106rpx;
  padding: 10rpx 16rpx;
  color: #7b806f;
  font-size: 27rpx;
  line-height: 1.25;
  text-align: center;
}

.category-item.active {
  background: #ffffff;
  color: #2f3327;
  font-size: 29rpx;
  font-weight: 900;
}

.category-item.active::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: #7a8f16;
  content: "";
}

.dish-list {
  flex: 1;
  height: 100%;
  box-sizing: border-box;
  padding: 24rpx 24rpx 190rpx;
  background: #ffffff;
}

.category-title {
  margin-bottom: 18rpx;
  color: #2f3327;
  font-size: 32rpx;
  font-weight: 900;
}

.dish-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 146rpx;
  margin-bottom: 22rpx;
}

.dish-thumb {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  border-radius: 20rpx;
  box-shadow: inset 0 -18rpx 34rpx rgba(90, 96, 64, 0.12);
}

.dish-thumb::after {
  position: absolute;
  right: 12rpx;
  bottom: 11rpx;
  width: 36rpx;
  height: 15rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
  content: "";
}

.dish-thumb text {
  z-index: 1;
  color: rgba(255, 255, 255, 0.96);
  font-size: 40rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.12);
}

.dish-main {
  flex: 1;
  min-width: 0;
  padding: 0 58rpx 0 22rpx;
}

.dish-name {
  color: #2f3327;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.dish-sales {
  margin-top: 14rpx;
  color: #9fa48f;
  font-size: 25rpx;
}

.dish-selected {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  margin-top: 8rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f1f6d7;
  color: #6f8312;
  font-size: 20rpx;
  font-weight: 900;
}

.plus-btn {
  position: absolute;
  right: 8rpx;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 44rpx;
  min-width: 44rpx;
  max-width: 44rpx;
  height: 44rpx;
  min-height: 44rpx;
  margin: -22rpx 0 0;
  padding: 0;
  border-radius: 50%;
  background: #2f302f;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 40rpx;
  box-shadow: 0 8rpx 16rpx rgba(47, 48, 47, 0.16);
}

.empty-dish {
  margin-top: 90rpx;
  color: #a4a894;
  font-size: 28rpx;
  text-align: center;
}

.settle-bar {
  position: fixed;
  right: 28rpx;
  bottom: 136rpx;
  left: 190rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 106rpx;
  box-sizing: border-box;
  padding: 14rpx 16rpx 14rpx 20rpx;
  border: 1rpx solid rgba(122, 143, 22, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 34rpx rgba(52, 58, 39, 0.12);
}

.cart-icon {
  position: relative;
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #f4f7df;
}

.cart-image {
  width: 58rpx;
  height: 58rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  border: 3rpx solid #ffffff;
  border-radius: 999rpx;
  background: #7a8f16;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 32rpx;
  text-align: center;
}

.random-btn {
  flex-shrink: 0;
  height: 58rpx;
  padding: 0 22rpx;
  border: 2rpx solid #dce7a5;
  border-radius: 999rpx;
  background: #ffffff;
  color: #6f8312;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 54rpx;
}

.cart-summary {
  flex: 1;
  min-width: 0;
  text-align: right;
}

.summary-main {
  color: #2f3327;
  font-size: 28rpx;
  font-weight: 900;
}

.summary-sub {
  margin-top: 4rpx;
  color: #9fa48f;
  font-size: 21rpx;
}

.order-btn {
  flex-shrink: 0;
  height: 82rpx;
  min-width: 146rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  background: #2f302f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
}

.order-btn.disabled {
  background: #ecece8;
  color: #b7b8ad;
}

.drawer-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  background: rgba(47, 51, 39, 0.22);
}

.cart-drawer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 61;
  box-sizing: border-box;
  max-height: 80vh;
  padding: 14rpx 30rpx 42rpx;
  border-radius: 42rpx 42rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 48rpx rgba(47, 51, 39, 0.14);
  transform: translateY(110%);
  transition: transform 180ms ease;
}

.cart-drawer.open {
  transform: translateY(0);
}

.drawer-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #dfe5cd;
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.drawer-title {
  color: #2f3327;
  font-size: 34rpx;
  font-weight: 900;
}

.drawer-subtitle {
  margin-top: 6rpx;
  color: #8c927c;
  font-size: 24rpx;
}

.drawer-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #f4f7df;
  color: #6f8312;
  font-size: 40rpx;
  line-height: 54rpx;
  text-align: center;
}

.drawer-empty {
  padding: 58rpx 0;
  color: #a4a894;
  font-size: 27rpx;
  text-align: center;
}

.drawer-list {
  max-height: 520rpx;
  overflow: hidden;
}

.drawer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 94rpx;
  border-top: 1rpx solid #eef0e7;
}

.drawer-row:first-child {
  border-top: 0;
}

.drawer-dish {
  min-width: 0;
}

.drawer-name {
  color: #2f3327;
  font-size: 28rpx;
  font-weight: 900;
}

.drawer-meta {
  margin-top: 6rpx;
  color: #9fa48f;
  font-size: 22rpx;
}

.drawer-stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #2f3327;
  font-size: 27rpx;
  font-weight: 900;
}

.drawer-stepper button {
  width: 46rpx;
  height: 46rpx;
  padding: 0;
  border-radius: 50%;
  background: #f4f7df;
  color: #6f8312;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.confirm-cart {
  width: 330rpx;
  height: 88rpx;
  margin: 28rpx auto 0;
  border-radius: 999rpx;
  background: #2f302f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
  box-shadow: 0 12rpx 26rpx rgba(47, 48, 47, 0.16);
}

.confirm-cart.disabled {
  background: #ecece8;
  color: #b7b8ad;
  box-shadow: none;
}

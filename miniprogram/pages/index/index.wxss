.hero {
  position: relative;
  overflow: hidden;
  padding: 44rpx 32rpx 32rpx;
  border-radius: 8rpx;
  background: #fffefa;
  box-shadow: 0 18rpx 48rpx rgba(63, 78, 68, 0.09);
}

.hero::after {
  position: absolute;
  right: -70rpx;
  top: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(237, 174, 73, 0.2);
  content: "";
}

.meal-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 36rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #f2f7ec;
}

.meal-label {
  color: #687067;
  font-size: 22rpx;
}

.meal-main {
  margin-top: 8rpx;
  color: #20241f;
  font-size: 34rpx;
  font-weight: 700;
}

.status-panel {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #26352f;
  color: #fff;
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f0b84d;
  box-shadow: 0 0 0 10rpx rgba(240, 184, 77, 0.16);
}

.status-copy {
  flex: 1;
}

.status-title {
  font-size: 28rpx;
  font-weight: 700;
}

.status-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.5;
}

.action-grid {
  display: flex;
  gap: 16rpx;
}

.action-card {
  flex: 1;
  min-height: 140rpx;
  box-sizing: border-box;
  padding: 20rpx 16rpx;
  border-radius: 8rpx;
  background: #fffefa;
  box-shadow: 0 12rpx 32rpx rgba(63, 78, 68, 0.07);
}

.action-title {
  font-size: 26rpx;
  font-weight: 700;
}

.action-desc {
  margin-top: 10rpx;
  color: #687067;
  font-size: 22rpx;
  line-height: 1.35;
}

.bottom-actions {
  position: fixed;
  right: 28rpx;
  bottom: 138rpx;
  left: 28rpx;
  display: flex;
  gap: 18rpx;
}

.bottom-actions .button {
  flex: 1;
}

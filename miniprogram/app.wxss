page {
  min-height: 100vh;
  background: #ffffff;
  color: #171717;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 174rpx;
}

.section {
  margin-top: 32rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(17, 17, 17, 0.06);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 12rpx;
  color: #747474;
  font-size: 28rpx;
  line-height: 1.6;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 28rpx;
  background: #ff4f3f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 30rpx rgba(255, 79, 63, 0.22);
}

.button.secondary {
  border: 1rpx solid rgba(255, 79, 63, 0.26);
  background: #fff5f2;
  color: #ff4f3f;
  box-shadow: none;
}

.muted {
  color: #747474;
}

.eyebrow {
  color: #ff4f3f;
  font-size: 24rpx;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff1ee;
  color: #ff4f3f;
  font-size: 22rpx;
  font-weight: 600;
}

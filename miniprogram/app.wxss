page {
  min-height: 100vh;
  background: #f6f7f1;
  color: #20241f;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 48rpx;
}

.section {
  margin-top: 32rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid rgba(39, 68, 59, 0.08);
  border-radius: 8rpx;
  background: #fffefa;
  box-shadow: 0 16rpx 40rpx rgba(63, 78, 68, 0.08);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 12rpx;
  color: #687067;
  font-size: 28rpx;
  line-height: 1.6;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 8rpx;
  background: #246b5a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.18), 0 14rpx 28rpx rgba(36, 107, 90, 0.2);
}

.button.secondary {
  border: 1rpx solid rgba(36, 107, 90, 0.35);
  background: rgba(36, 107, 90, 0.06);
  color: #246b5a;
  box-shadow: none;
}

.muted {
  color: #687067;
}

.eyebrow {
  color: #246b5a;
  font-size: 24rpx;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(36, 107, 90, 0.08);
  color: #246b5a;
  font-size: 22rpx;
  font-weight: 600;
}

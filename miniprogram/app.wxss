page {
  min-height: 100vh;
  background: #f7f3ea;
  color: #27231d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.section {
  margin-top: 28rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid #ece3d3;
  border-radius: 8rpx;
  background: #fffdf8;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 12rpx;
  color: #716a5e;
  font-size: 28rpx;
  line-height: 1.6;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 8rpx;
  background: #2f6f5e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.button.secondary {
  border: 1rpx solid #2f6f5e;
  background: #fffdf8;
  color: #2f6f5e;
}

.muted {
  color: #716a5e;
}
